classDiagram
    class ModeManager {
        +modes: dict
        +current_mode: ContextMode
        +get_mode(mode_name)
        +set_mode(mode_name)
    }

    class ContextMode {
        +activate()
        +deactivate()
    }

    class Event {
        +callbacks: list
        +subscribe(callback)
        +unsubscribe(callback)
        +fire(*args, **kwargs)
        +__iadd__(callback)
        +__isub__(callback)
    }

    class ConfigStorage {
        +storage: dict
        +load()
        +save(section_name, attr_name, value)
    }

    class BaseConfig {
        +_sections: dict
        +_storage: ConfigStorage
        +default: dict
        +__getattr__(section_name)
        +_create_section(section_name)
        +set_storage(storage)
        +register_section(section_name, section_class)
        +load_config()
        +notify_change(section_name, attr_name, value)
    }

    class ConfigSection {
        +_name: str
        +_parent: BaseConfig
        +_data: dict
        +__getattr__(attr)
        +__setattr__(attr, value)
    }

    class TypedConfigSection {
        +__getattr__(attr)
        +__setattr__(attr, value)
    }

    class ConfigListener {
        +on_config_change(section, attribute, value)
    }

    class Allocator {
        +_registry: dict
        +initializers: list
        +config: BaseConfig
        +has_service(key)
        +register(key, instance)
        +singleton(key, instance)
        +get_instance(key)
        +init_services()
        +add_initializer(initializer)
    }

    class Module {
        +name: str
        +dependencies: list
        +enabled: bool
        +initiailized: bool
        +loaded: bool
        +init(app)
        +load(app)
        +unload(app)
    }

    class Resource {
        +name: str
        +tags: list
        +app: GlueApp
    }

    class Service {
        +init(config)
        +instance()
    }

    class ResourcesRepo {
        +resources: list
        +get_by_type_one(_type)
        +get_by_name_one(name)
        +register(resource)
    }

    class GlueApp {
        +config: BaseConfig
        +modules: list
        +resources_repo: ResourcesRepo
        +add_module(module)
        +init()
        +Exit()
        +Run()
    }

    ModeManager --> ContextMode
    BaseConfig --> ConfigStorage
    BaseConfig --> ConfigSection
    TypedConfigSection --> ConfigSection
    ConfigListener --> BaseConfig
    Allocator --> BaseConfig
    Allocator --> Service
    GlueApp --> BaseConfig
    GlueApp --> Module
    GlueApp --> ResourcesRepo
    ResourcesRepo --> Resource
    Service --> Resource
